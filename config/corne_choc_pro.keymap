        // - LEFT LAYERS --------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        
        extra_layer_2 {
            display-name = "SYMBOL";
            bindings = <
            //╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮         ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
                ___           &kp AT        &kp HASH      &dllr_mr      &kp PRCNT     &kp GRAVE     XXX XXX   ___           ___           ___           ___           ___           ___   
            //├─────────────┼─────────────┼─────────────┼─────────────┬─────────────┼─────────────┤         ├─────────────┬─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
                ___           &kp AMPS      &kp FSLH      &kp MINUS     &kp EQUAL     &kp ASTRK     XXX XXX   ___           &kp RSHFT     &kp RCTRL     &kp RALT      &kp RGUI      ___   
            //├─────────────┼─────────────┼─────────────┼─────────────┬─────────────┼─────────────┤         ├─────────────┬─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
                ___           &kp PIPE      &kp BSLH      &kp UNDER     &kp PLUS      &kp CARET               ___           ___           ___           ___           ___           ___   
            //╰─────────────┼─────────────┴─────────────┼─────────────┬─────────────┼─────────────┤         ├─────────────┬─────────────┼─────────────┼─────────────┴───────────────────────────╯
                                                          ___           ___           ___                     ___           ___           ___   
            //                                          ╰─────────────┴─────────────┴─────────────╯         ╰─────────────┴─────────────┴─────────────╯
           >;
        };

        extra_layer_3 {
            display-name = "NUMBER";
            bindings = <
            //╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮         ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
                ___           ___           &kp N7        &kp N8        &kp N9        ___           XXX XXX   ___           ___           ___           ___           ___           ___   
            //├─────────────┼─────────────┼─────────────┼─────────────┬─────────────┼─────────────┤         ├─────────────┬─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
                ___           &kp N0        &kp N4        &kp N5        &kp N6        ___           XXX XXX   ___           &kp RSHFT     &kp RCTRL     &kp RALT      &kp RGUI      ___   
            //├─────────────┼─────────────┼─────────────┼─────────────┬─────────────┼─────────────┤         ├─────────────┬─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
                ___           ___           &kp N1        &kp N2        &kp N3        ___                     ___           ___           ___           ___           ___           ___   
            //╰─────────────┼─────────────┴─────────────┼─────────────┬─────────────┼─────────────┤         ├─────────────┬─────────────┼─────────────┼─────────────┴───────────────────────────╯
                                                          ___           ___           ___                     ___           ___           ___   
            //                                          ╰─────────────┴─────────────┴─────────────╯         ╰─────────────┴─────────────┴─────────────╯
            >;
        };

        extra_layer_4 {
            display-name = "FUNC"; 
            bindings = <
            //╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮         ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
                ___           &kp F12       &kp F7        &kp F8        &kp F9        ___           XXX XXX   ___           ___           ___           ___           ___           ___   
            //├─────────────┼─────────────┼─────────────┼─────────────┬─────────────┼─────────────┤         ├─────────────┬─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
                ___           &kp F11       &kp F4        &kp F5        &kp F6        ___           XXX XXX   ___           &kp RSHFT     &kp RCTRL     &kp RALT      &kp RGUI      ___   
            //├─────────────┼─────────────┼─────────────┼─────────────┬─────────────┼─────────────┤         ├─────────────┬─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
                ___           &kp F10       &kp F1        &kp F2        &kp F3        ___                     ___           ___           ___           ___           ___           ___   
            //╰─────────────┼─────────────┴─────────────┼─────────────┬─────────────┼─────────────┤         ├─────────────┬─────────────┼─────────────┼─────────────┴───────────────────────────╯
                                                          ___           ___           ___                     ___           ___           ___   
            //                                          ╰─────────────┴─────────────┴─────────────╯         ╰─────────────┴─────────────┴─────────────╯
