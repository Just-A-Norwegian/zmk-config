        // - GAMING LAYER --------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // (mostly normal querty layout but shifter over by one row, also juts left side of keyboard is needed)

        extra_layer_6 {
            display-name = "GAMING";
            bindings = <
                ___    ___    ___    ___    ___    ___    ___    ___    ___    ___    ___    ___    ___    ___   
